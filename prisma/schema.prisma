generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AppSettings {
  id           Int      @id @default(1)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DiaryEntry {
  id        String   @id @default(cuid())
  date      String   @unique

  happenings String?
  gratitude  String?

  sleepBedTime  String?
  sleepWakeTime String?

  bodyStatus Int?
  bodyNote   String?
  soulStatus Int?
  soulNote   String?

  games    String?
  shopping String?

  customFields  String?
  searchContent String?

  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  exercises Exercise[]
  meals     Meal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Exercise {
  id        String     @id @default(cuid())
  diaryId   String
  diary     DiaryEntry @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  type      String
  duration  Int?
  note      String?
  createdAt DateTime   @default(now())
}

model Meal {
  id        String     @id @default(cuid())
  diaryId   String
  diary     DiaryEntry @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  mealType  String
  content   String
  createdAt DateTime   @default(now())
}

model Quote {
  id         String       @id @default(cuid())
  text       String
  author     String?
  source     String?
  isFavorite Boolean      @default(false)
  diaries    DiaryEntry[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}
